{
  "id": "automation.feishu_bot",
  "name": "飞书机器人通知自动化",
  "version": "1.0.0",
  "category": "automation",
  "description": "监听任务和系统事件，通过飞书群机器人发送通知消息，适用于团队群内的运行播报和异常提醒。",
  "author": "T3MT Official",
  "homepage": "",
  "license": "MIT",
  "core_version": ">=1.0.0 <2.0.0",
  "contract_version": "1.0",
  "capabilities": [
    "automation.event_handler",
    "notification.feishu"
  ],
  "backend": {
    "entry": "backend.plugin:plugin"
  },
  "permissions": [
    "network",
    "secret.read"
  ],
  "dependencies": [],
  "optional_dependencies": [],
  "config_schema": [
    {
      "key": "enabled",
      "label": "启用插件",
      "type": "boolean",
      "required": false,
      "default": true,
      "description": "是否启用飞书机器人通知自动化。",
      "secret": false,
      "group": "基础设置"
    },
    {
      "key": "webhook_url",
      "label": "机器人回调地址",
      "type": "string",
      "required": true,
      "default": "",
      "description": "飞书群机器人的 webhook 回调地址。",
      "secret": true,
      "group": "基础设置"
    },
    {
      "key": "secret",
      "label": "签名密钥",
      "type": "string",
      "required": false,
      "default": "",
      "description": "启用签名校验时使用的安全密钥。",
      "secret": true,
      "group": "基础设置"
    },
    {
      "key": "enabled_events",
      "label": "启用事件列表",
      "type": "string",
      "required": false,
      "default": "task.completed,task.failed",
      "description": "需要发送通知的事件类型列表，多个值用英文逗号分隔。",
      "secret": false,
      "group": "通知设置"
    },
    {
      "key": "message_card_title",
      "label": "卡片标题前缀",
      "type": "string",
      "required": false,
      "default": "T3MT 系统通知",
      "description": "飞书卡片消息展示时的标题前缀。",
      "secret": false,
      "group": "通知设置"
    }
  ],
  "ui": {
    "menus": [],
    "settings_sections": [
      {
        "key": "notification.feishu",
        "title": "飞书机器人通知"
      }
    ],
    "task_templates": []
  },
  "healthcheck": {
    "enabled": true,
    "interval_seconds": 300
  }
}
